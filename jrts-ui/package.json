{
  "name": "jrts-ui",
  "version": "1.0.0",
  "description": "JABBER Red Teaming Suite - Electron/React Frontend",
  "main": "electron/main.cjs",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "preview": "vite preview",
    "electron:dev": "concurrently \"vite\" \"wait-on http://localhost:5173 && electron . --dev\"",
    "electron:build": "vite build && electron-builder",
    "start": "vite"
  },
  "keywords": ["jrts", "red-team", "security", "cybersecurity"],
  "author": "Funbinet (dancan.tech)",
  "license": "PROPRIETARY",
  "dependencies": {
    "lucide-react": "^1.8.0",
    "react": "^19.2.5",
    "react-dom": "^19.2.5",
    "react-router-dom": "^7.14.1"
  },
  "devDependencies": {
    "@vitejs/plugin-react": "^6.0.1",
    "concurrently": "^9.2.1",
    "electron": "^41.2.1",
    "electron-builder": "^26.8.1",
    "vite": "^8.0.8",
    "wait-on": "^9.0.5"
  },
  "build": {
    "appId": "com.jabber.jrts",
    "productName": "JRTS - Jabber Red Teaming Suite",
    "linux": {
      "target": ["AppImage", "deb"],
      "category": "Utility"
    },
    "directories": {
      "output": "release"
    },
    "files": [
      "dist/**/*",
      "electron/**/*"
    ]
  }
}
